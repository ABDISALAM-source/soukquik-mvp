  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:migrate": "node scripts/run-sql.js migrations",
    "db:seed": "node scripts/run-sql.js seed",
    "test": "jest --runInBand"
  },
  "dependencies": {
