{
  "expo": {
    "name": "SoukQuik",
    "slug": "soukquik",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#FAF7F2"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SoukQuik utilise ta position pour te montrer les boutiques et prestataires les plus proches de toi."
      }
    },
    "android": {
      "package": "com.soukquik.app",
      "permissions": ["ACCESS_COARSE_LOCATION", "ACCESS_FINE_LOCATION"],
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      }
    },
    "extra": {
      "apiUrl": "http://localhost:4000/api",
      "eas": {
        "projectId": "843f757a-2729-4ba3-84fb-0d19f0395014"
      }
    },
    "owner": "khayali",
    "plugins": [
      "expo-font",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SoukQuik utilise ta position pour te montrer les boutiques et prestataires les plus proches de toi."
        }
      ]
    ]
  }
}
